{
  "manifest_version": 3,
  "name": "KhabarCheck - News Bias Detector",
  "version": "1.0.0",
  "description": "Detect political bias in news articles instantly with AI-powered analysis",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "/extension/icons/icon-16.png",
    "48": "/extension/icons/icon-48.png",
    "128": "/extension/icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KhabarCheck - Analyze This Article"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
